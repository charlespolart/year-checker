{
  "expo": {
    "name": "Dian Dian",
    "slug": "dian-dian",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f5f0d0"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.mydiandian",
      "associatedDomains": [
        "applinks:mydiandian.app"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "Not used",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#f5f0d0",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "app.mydiandian"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "Dian Dian",
      "shortName": "Dian Dian"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      "expo-localization"
    ],
    "extra": {
      "eas": {
        "projectId": "70239696-1f18-4e5e-b051-2d1f8f3b90db"
      }
    },
    "owner": "overridedev"
  }
}
